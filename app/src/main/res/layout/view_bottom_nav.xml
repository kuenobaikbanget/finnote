<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/customBottomNav"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="16dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingTop="10dp"
    android:paddingEnd="8dp"
    android:paddingBottom="12dp">

    <!-- Home -->
    <LinearLayout
        android:id="@+id/btnNavHome"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="5dp"
        android:paddingEnd="8dp"
        android:paddingBottom="5dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_home"
            app:tint="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:contentDescription="@string/nav_home"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_home"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:textColor="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:layout_marginTop="2dp"/>

        <View
            android:layout_width="20dp"
            android:layout_height="2dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_bottom_nav_indicator"
            android:duplicateParentState="true" />

    </LinearLayout>

    <!-- Transaksi -->
    <LinearLayout
        android:id="@+id/btnNavTransaction"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="5dp"
        android:paddingEnd="8dp"
        android:paddingBottom="5dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_transaction"
            app:tint="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:contentDescription="@string/nav_transaction"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_transaction"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:textColor="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:layout_marginTop="2dp"/>

        <View
            android:layout_width="20dp"
            android:layout_height="2dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_bottom_nav_indicator"
            android:duplicateParentState="true" />

    </LinearLayout>

    <!-- Profil -->
    <LinearLayout
        android:id="@+id/btnNavProfile"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="5dp"
        android:paddingEnd="8dp"
        android:paddingBottom="5dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_profile"
            app:tint="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:contentDescription="@string/profil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/profil"
            android:textSize="11sp"
            android:fontFamily="@font/inter_medium"
            android:textColor="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:layout_marginTop="2dp"/>

        <View
            android:layout_width="20dp"
            android:layout_height="2dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_bottom_nav_indicator"
            android:duplicateParentState="true" />

    </LinearLayout>

</LinearLayout>
