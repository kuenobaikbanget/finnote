<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/customBottomNav"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="16dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingTop="16dp"
    android:paddingEnd="8dp"
    android:paddingBottom="16dp">

    <!-- Home -->
    <LinearLayout
        android:id="@+id/btnNavHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_home"
            android:tint="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:contentDescription="Home"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_home"
            android:textSize="10sp"
            android:textColor="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Transaksi -->
    <LinearLayout
        android:id="@+id/btnNavTransaction"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_transaction"
            android:tint="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:contentDescription="Transaksi"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_transaction"
            android:textSize="10sp"
            android:textColor="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Statistik -->
    <LinearLayout
        android:id="@+id/btnNavStatistik"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chart"
            android:tint="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:contentDescription="Statistik"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statistik"
            android:textSize="10sp"
            android:textColor="@color/nav_item_selector"
            android:duplicateParentState="true"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

</LinearLayout>
