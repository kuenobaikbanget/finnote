<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/logoutSheetContent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_discard"
    android:clipToOutline="true"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="10dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_bottom_sheet_handle"
        android:importantForAccessibility="no" />

    <TextView
        android:id="@+id/tvLogoutTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="@font/inter_bold"
        android:includeFontPadding="false"
        android:lineSpacingExtra="2dp"
        android:text="@string/profile_logout_dialog_title"
        android:textColor="@color/black"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/tvLogoutMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter"
        android:lineSpacingExtra="3dp"
        android:text="@string/profile_logout_dialog_message"
        android:textColor="@color/text_muted_accessible"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogoutConfirm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/inter_bold"
        android:text="@string/profile_logout_confirm"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:backgroundTint="@color/expense_coral_accessible"
        app:cornerRadius="18dp"
        app:rippleColor="@color/expense_tint" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogoutCancel"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/inter_medium"
        android:text="@string/profile_logout_cancel"
        android:textAllCaps="false"
        android:textColor="@color/text_muted_accessible"
        android:textSize="14sp"
        app:backgroundTint="@android:color/transparent"
        app:cornerRadius="18dp"
        app:rippleColor="@color/divider_mist" />

</LinearLayout>
