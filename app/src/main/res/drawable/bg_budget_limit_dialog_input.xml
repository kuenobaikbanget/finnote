<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/mint_cream" />
            <stroke
                android:width="1.5dp"
                android:color="@color/deep_teal" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/mint_cream" />
            <stroke
                android:width="1dp"
                android:color="@color/divider_mist" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
