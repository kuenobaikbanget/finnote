<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/broken_white" />
        </shape>
    </item>
    <item android:gravity="top|start">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.15"
                android:centerY="0.0"
                android:gradientRadius="320dp"
                android:startColor="#14ABCDCA"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
