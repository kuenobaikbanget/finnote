<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="315"
                android:startColor="@color/income_tint"
                android:centerColor="@color/broken_white"
                android:endColor="@color/white" />
        </shape>
    </item>

    <item android:gravity="top|start">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.1"
                android:centerY="0.1"
                android:gradientRadius="360dp"
                android:startColor="#1AC4F7C3"
                android:endColor="#00000000" />
        </shape>
    </item>

</layer-list>
